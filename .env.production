# Variáveis de ambiente para build de produção (GitHub Pages)
# Estas variáveis são usadas durante o build do frontend
# Valores sensíveis devem ser configurados como secrets no GitHub

# Analytics (opcional - deixar vazio para desabilitar)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# OAuth (necessário para login via OAuth)
# Configure como secret no GitHub: Settings > Secrets and variables > Actions
VITE_OAUTH_PORTAL_URL=
VITE_APP_ID=
